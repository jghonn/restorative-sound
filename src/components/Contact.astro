---
import { site } from '../data/site';
import theme from '../data/theme.json';
import contact from '../data/contact.json';
import { sectionProps } from '../utils/theme';
---

<section {...sectionProps(theme.contact, '#3e2c22')} id="contact">
  <div class="container grid">
    <div class="intro reveal">
      <p class="eyebrow">Contact / Inquiry</p>
      <h2>{contact.heading}</h2>
      <p class="sub">{contact.body}</p>

      <ul class="details">
        <li>
          <span class="label">Email</span>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </li>
        <li>
          <span class="label">Phone</span>
          <a href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </li>
      </ul>
    </div>

    <!-- Netlify Forms: detected at deploy via data-netlify + hidden form-name. -->
    <form
      class="form reveal"
      name="inquiry"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="inquiry" />
      <p class="hidden">
        <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
      </p>

      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="offering">I’m interested in</label>
        <select id="offering" name="offering">
          <option>Postpartum Restorative Sessions</option>
          <option>Christian Contemplative Gatherings</option>
          <option>Private Restorative Sessions</option>
          <option>A group / event booking</option>
          <option>Something else</option>
        </select>
      </div>

      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="4" required></textarea>
      </div>

      <button class="btn" type="submit">Send inquiry</button>
    </form>
  </div>

  <p class="disclaimer container">
    Sessions offer supportive rest and relaxation and are not a substitute for medical or
    mental-health care.
  </p>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }
  .sub {
    color: rgba(246, 241, 232, 0.82);
    max-width: 42ch;
  }
  .details {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .details .label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 0.15rem;
  }
  .details a {
    color: var(--bone);
    font-size: 1.1rem;
  }
  .details a:hover {
    color: var(--sand);
  }

  .form {
    display: grid;
    gap: 1.1rem;
  }
  .field {
    display: grid;
    gap: 0.4rem;
  }
  .field label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sand);
  }
  input,
  select,
  textarea {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--bone);
    background: rgba(246, 241, 232, 0.06);
    border: 1px solid rgba(246, 241, 232, 0.28);
    border-radius: var(--radius);
    padding: 0.75rem 0.9rem;
    width: 100%;
  }
  select option {
    color: var(--charcoal);
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--sand);
    background: rgba(246, 241, 232, 0.1);
  }
  textarea {
    resize: vertical;
  }
  .form .btn {
    justify-self: start;
    margin-top: 0.4rem;
  }
  .hidden {
    display: none;
  }

  .disclaimer {
    margin: clamp(2.5rem, 5vw, 4rem) auto 0;
    font-size: 0.85rem;
    color: rgba(246, 241, 232, 0.55);
    text-align: center;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
